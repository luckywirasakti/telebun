{
  "name": "@luckywirasakti/telebun",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.1.0",
  "description": "Telegram QR Authentication — seamless login via Telegram QR scan for Node.js web apps",
  "keywords": [
    "telegram",
    "qr",
    "auth",
    "authentication",
    "login",
    "telegram-login",
    "qr-auth",
    "telegram-bot"
  ],
  "homepage": "https://github.com/luckywirasakti/telebun#readme",
  "bugs": {
    "url": "https://github.com/luckywirasakti/telebun/issues"
  },
  "license": "MIT",
  "author": "Lucky Wirasakti <lucky.wirasakti@gmail.com>",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/middleware/express.d.ts",
      "default": "./dist/middleware/express.js"
    },
    "./http": {
      "types": "./dist/middleware/http.d.ts",
      "default": "./dist/middleware/http.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "node --test \"test/**/*.test.js\"",
    "test:ts": "npx tsx --test test/*.test.ts",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepack": "npm run clean && npm run build"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.5",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luckywirasakti/telebun.git"
  }
}
